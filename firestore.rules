rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'displayName', 'premium', 'points'])
          && data.uid == request.auth.uid
          && data.email is string
          && data.points is int
          && data.premium is bool;
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) 
        && isValidUser(incoming())
        && incoming().uid == existing().uid
        && incoming().email == existing().email;

      // 2. Chats Subcollection
      match /chats/{chatId} {
        function isValidChat(data) {
          return data.keys().hasAll(['userId', 'role', 'content', 'timestamp'])
            && data.userId == request.auth.uid
            && data.role in ['user', 'model']
            && data.content is string
            && data.content.size() <= 5000;
        }

        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidChat(incoming());
      }

      // 3. Mock Tests Subcollection
      match /mockTests/{testId} {
        function isValidTest(data) {
          return data.keys().hasAll(['userId', 'category', 'score', 'totalQuestions', 'timestamp'])
            && data.userId == request.auth.uid
            && data.score is int
            && data.totalQuestions is int;
        }

        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidTest(incoming());
      }
    }
  }
}
